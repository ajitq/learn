[Unit]
Description=Learn Anything
After=network.target

[Service]
Type=simple
# Adjust User and WorkingDirectory to where you cloned the repo.
User=learn
WorkingDirectory=/opt/learn
ExecStart=/usr/bin/node server.js
Environment=NODE_ENV=production
Environment=PORT=3000
# Persistent data (sqlite db + uploaded photos) lives here:
Environment=DATA_DIR=/opt/learn/data
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
